    radius=r;
  }
  public double getSpereSurface()
  {
    return 4*CirclePi*Math.pow(radius,2);
  }
  public double getSphereVolume()
  {
    return (4/3)*CirclePi*Math.pow(r,3);
  }
  public double getRadius()
