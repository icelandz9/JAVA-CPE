import java.util.Random;

public class Exam3 {
    public static void main(String[] args) {
        Random random = new Random();
        int sumOdd = 0;

        System.out.println("Generated 5x5 Numbers:");
        for (int i = 1; i <= 5; i++) { // Loop แถว
            for (int j = 1; j <= 5; j++) { // Loop คอลัมน์
                int num = random.nextInt(3001) - 1500; // สุ่มค่า [-1500, 1500]
                System.out.printf("%6d ", num); // แสดงค่าที่สุ่มได้

                if (num % 2 != 0) { // ถ้าเป็นเลขคี่ให้บวกเข้า sumOdd
                    sumOdd += num;
                }
            }
            System.out.println(); // ขึ้นบรรทัดใหม่
        }

        // แสดงผลรวมของเลขคี่
        System.out.println("\nThe sum of all odd numbers is: " + sumOdd);
    }
}
