import java.util.Scanner;
public class quiz4_2 {
  public static void main(String[] args) { 
  Scanner sn = new Scanner(System.in);
  double cone,sphere,square;
  double a,w,l,rad,h,h2,num,sum2,r;
  System.out.print("Find surface of 1.square 2.sphere 3.cone : ");
  a = sn.nextDouble();
 if(a==1)//ОЗ.МдЧЪешрЫХешТС
  {
    System.out.print("Enter width of square:" );
    w = sn.nextInt();
    System.out.print("Enter leght of square:" );
    l = sn.nextInt();
    System.out.print("Enter high of square:" );
    h = sn.nextInt();
    square = calSurface(w,l,h);
    System.out.println("Area of square is:" +square);
  }
 if(a == 2)//ОЗ.МдЧЁХС
  {
    System.out.print("Enter radius of sphere:");
