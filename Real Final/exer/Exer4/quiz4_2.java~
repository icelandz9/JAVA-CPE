 }
  }
  public static double calSurface(double w,double l,double h)
  {
   return(2*l*w)+(2*w*h)+(2*h*l);
   }
   
  public static double calSurface(double rad)
  {
   return  4*Math.PI*Math.pow(rad,(2));
  }
  
  public static double calSurface(double rad,double h)
  { 
  return Math.sqrt((Math.pow(rad,(2))*Math.pow(h,(2))));
    
  }
}


