public class metric{
  public static void main(String[] args){
    int i, ran=0, num=0;
    for(i=1;i<=16;i++)
    {
      ran = (int)((Math.random()*1999)-1000);
      if(ran>=0)
      {System.out.print(" ");}
      if(ran>-10 && ran<10)
      {System.out.print(" ");}
      if(ran>-100 && ran<100)
      {System.out.print(" ");}
      System.out.print("  "+ran);
      if(i%4==0)
      System.out.print("\n");
      num = num+ran;
    }
    System.out.println("The sum of all numbers in the matrix is "+num);
  }
}