import javax.swing.JOptionPane;

public class Exam6 {
    public static void main(String[] args) {
        int n = Integer.parseInt(JOptionPane.showInputDialog("Enter the number of n :"));

        int firstsum = 0;
        
        for (int i = 0; i < n ; i++) {
            if (i % 7 == 0 || i % 5 == 0) {
     firstsum += 2 * i; 
    }else{
     firstsum += 0 * i; 
    }

        }

     
        int secondsum = 0 ;

        for (int i = 0; i < n; i++) {
            if (i % 7 == 0 || i % 5 == 0) {
     secondsum += (Math.pow(-1,1+i)) / (2 * i) - 1; 
    }else{
     secondsum += 0 * i; 
    }

        }
        
        

        int T = firstsum + secondsum;

        JOptionPane.showMessageDialog(null, String.format(" value of T: %d\n", T));
        
    }
}
