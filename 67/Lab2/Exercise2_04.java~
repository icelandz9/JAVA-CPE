import java.util.Scanner;
public class Exercise2_03 {
  public static void main(String[] agrs) {
    Scanner sn = new Scanner(System.in);
    System.out.print("Enter an integer : ");
    int integer = sn.nextInt();
    if (integer%3 == 0 && integer%11 == 0) {
      System.out.print(integer+" is divisible by both 3 and 11");
    } else if (integer%3 == 0 || integer%11 == 0) {
      System.out.print(integer+" is divisible by both 3 or 11, but not both");
    } else {
      System.out.print(integer+" is not divisible by either 3 or 11");
    }
    
    
    sn.close();
  }
} 