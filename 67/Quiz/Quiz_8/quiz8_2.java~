import java.util.Scanner;
public class quiz8_2 {
  public static void main(String[] args) {
    FileInputStream f_in = null;
    File fname = new File("D:\\CharBuffData.txt");
    System.out.println("Read from KB");
    System.out.println("=====================");
    Scanner sn = new Scanner(System.in);
    while(1) {
      System.out.println("Enter Data : ");
      String x = sn.nextLine();
      if(x=='$') {
        break;
      }
    }
    System.out.println("Data are saved to File : ");
    System.out.println("=====================");
    try {
      f_in = new FileInputStream(fname);
      System.out.println("Read Data from File : " + fname);
      int c;
      while ((c = f_in.read()) != -1){
        System.out.println(c);
      }
    }
    catch (IOException e){
      System.out.println(e+"\nหมายถึง \"ข้อผิดพลาด" + "ที่เกิดจากไม่พบไฟล์ข้อมูลที่ต้องการ\"");
    }
    System.out.println("=====================");
    sn.close();
  }
}