public class Circle
{
  public double CirclePi = 3.14;
  private double r;
  public Circle(double radius)
  {
    r=radius;
  }
  public double getArea()
  {
    return CirclePi*Math.pow(r,2);
  }
  public double getVolume()
  {
    return (4/3)*CirclePi*Math.pow(r,3);
  }
  public double getCircumference()
  {
    return 2*CirclePi*r;
  }
}