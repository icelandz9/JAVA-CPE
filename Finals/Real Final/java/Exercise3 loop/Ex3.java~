public class Ex3
{
  public static void main(String[] args)
  {
    int j=0;
    for(int i=1;i<=81;i++)
    {
      System.out.print(i);
      j++;
        if(j%2!=0)
      {
        System.out.print("\n");
      }
        else
        {
          System.out.print("\t");
        }
        
    }
  }
}